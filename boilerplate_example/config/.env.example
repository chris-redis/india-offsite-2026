# =============================================================================
# BOILERPLATE PROJECT - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# GRAFANA / PROMETHEUS
# -----------------------------------------------------------------------------
GRAFANA_URL=https://monitoringcloud.redislabs.com/grafana
GRAFANA_API_TOKEN=your_grafana_api_token_here
PROM_DATASOURCE_UID=P9E3C2526B28249DF

# -----------------------------------------------------------------------------
# GLEAN AI
# -----------------------------------------------------------------------------
GLEAN_BASE_URL=https://redis-be.glean.com/
GLEAN_API_TOKEN=your_glean_api_token_here

# -----------------------------------------------------------------------------
# SMDB (MySQL Database via SSH Tunnel)
# -----------------------------------------------------------------------------
# Note: Requires SSH tunnel to be running:
SMDB_HOST=127.0.0.1
SMDB_PORT=3306
SMDB_USER=smdb_username
SMDB_PASSWORD=your_smdb_password_here
SMDB_DATABASE=garantiaSM
SMDB_CERT_FILE=certs/your_cert.pem
SMDB_KEY_FILE=certs/your_key.pem

# -----------------------------------------------------------------------------
# CLOUD EXPORTER API
# -----------------------------------------------------------------------------
CLOUD_EXPORTER_URL=https://api.cloud-cluster-exporter.redislabs.com/json?data_type=cluster_info
CLOUD_EXPORTER_CERT_FILE=certs/your_cert.pem
CLOUD_EXPORTER_KEY_FILE=certs/your_key.pem

# -----------------------------------------------------------------------------
# SQUADCAST
# -----------------------------------------------------------------------------
SQUADCAST_BEARER_TOKEN=your_squadcast_bearer_token_here
SQUADCAST_AUTH=https://auth.eu.squadcast.com/oauth/access-token
SQUADCAST_URL_TEAMS=https://api.eu.squadcast.com/v3/teams
SQUADCAST_URL_SERVICES=https://api.eu.squadcast.com/v3/services
SQUADCAST_URL_INCIDENTS=https://api.eu.squadcast.com/v3/incidents

# -----------------------------------------------------------------------------
# FIREHYDRANT
# -----------------------------------------------------------------------------
FIREHYDRANT_API_TOKEN=your_firehydrant_api_token_here
FIREHYDRANT_BASE_URL=https://api.firehydrant.io/v1

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# -----------------------------------------------------------------------------
# GCP
# -----------------------------------------------------------------------------
# Option 1: Service Account JSON file path
GOOGLE_APPLICATION_CREDENTIALS=certs/gcp_service_account.json
# Option 2: Individual credentials (if not using service account file)
GCP_PROJECT_ID=your_gcp_project_id
GCP_CLIENT_EMAIL=your_service_account_email
GCP_PRIVATE_KEY=your_private_key_here

# -----------------------------------------------------------------------------
# WILDMOOSE
# -----------------------------------------------------------------------------
# WildMoose API for playbook-based debugging agents
# Get your JWT token from Auth0 or WildMoose admin
WILDMOOSE_BASE_URL=https://api.wildmoose.ai
WILDMOOSE_API_TOKEN=your_jwt_token_here

# -----------------------------------------------------------------------------
# JIRA
# -----------------------------------------------------------------------------
# Atlassian Jira API - uses API tokens (not password)
# Generate token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://redislabs.atlassian.net
JIRA_USER=your_email@redis.com
JIRA_API_TOKEN=your_jira_api_token_here

